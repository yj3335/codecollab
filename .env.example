# Development environment template
# Copy to .env.local and fill in your values

# General
STAGE=dev
LOG_LEVEL=debug
NODE_ENV=development

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Collab Server
PORT=8000
REDIS_URL=redis://localhost:6379
DYNAMODB_TABLE_SESSIONS=codecollab-sessions-dev
S3_BUCKET_LOGS=codecollab-edit-logs-dev
S3_BUCKET_CODE=codecollab-code-dev
AWS_REGION=us-east-1

# Execution API
PORT=8001
ECS_CLUSTER=codecollab-cluster-dev
ECS_TASK_DEFINITION=codecollab-runner-dev
AWS_REGION=us-east-1

# Translation
GEMINI_API_KEY=your-gemini-key-here

# AWS (if not using AWS CLI credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
