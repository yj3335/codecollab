# Collab server (HTTP + WebSocket on same port by default)
REACT_APP_COLLAB_API_URL=http://localhost:8000
REACT_APP_COLLAB_WS_URL=ws://localhost:8000

# Execution API (local Docker runner + run stream)
REACT_APP_EXECUTION_API_URL=http://localhost:8001

# Defaults for POST /api/sessions (optional)
REACT_APP_DEFAULT_SESSION_NAME=Untitled session
REACT_APP_DEFAULT_LANGUAGE=python
