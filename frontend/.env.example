# --- Local development -------------------------------------------------------
# Collab server (HTTP + WebSocket on same port by default)
REACT_APP_COLLAB_API_URL=http://localhost:8000
REACT_APP_COLLAB_WS_URL=ws://localhost:8000

# Execution API (local Docker runner + run stream)
REACT_APP_EXECUTION_API_URL=http://localhost:8001

# --- Deployed (CloudFront + ALB) ---------------------------------------------
# Replace <domain> with the CloudFront distribution domain or your custom domain.
# All HTTP/WS traffic is served from a single origin, with path-based routing
# behind CloudFront/ALB.
#
# REACT_APP_COLLAB_API_URL=https://<domain>
# REACT_APP_EXECUTION_API_URL=https://<domain>
# REACT_APP_COLLAB_WS_URL=wss://<domain>/ws
#

# --- Defaults for new sessions ----------------------------------------------
REACT_APP_DEFAULT_SESSION_NAME=Untitled session
REACT_APP_DEFAULT_LANGUAGE=python
